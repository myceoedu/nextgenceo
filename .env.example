# Supabase (Dashboard → Project Settings → API)
# URL looks like: https://<project-ref>.supabase.co
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=

# Optional: canonical public URL for password-reset redirects (defaults to the current request)
# Use your Next site URL, e.g. http://localhost:3000 locally or https://yourdomain.com in prod
# NEXT_PUBLIC_SITE_URL=http://localhost:3000
